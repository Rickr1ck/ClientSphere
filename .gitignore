# ClientSphere CRM - .gitignore
# Prevents sensitive files and build artifacts from being committed to GitHub

# ===========================
# Sensitive Configuration (NEVER commit these!)
# ===========================

# Environment files with secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# User-specific settings
*.user
*.userosscache
*.sln.docstates

# User-specific files
*.rsuser
*.suo
*.*suo
*user*
*user.*

# Build results (generated files)
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
*.cache
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio workspace
*.suo
*.user
*.userosscache
*.sln.docstates

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# ===========================
# .NET / ASP.NET Core
# ===========================

# ASP.NET Core publish output (NEVER commit published apps!)
publish/
*.pubxml
*.pubxml.user

# Entity Framework migrations (keep migration files, ignore runtime)
# Keep: Migrations/*.cs
# Keep: Migrations/*.Designer.cs
# Ignore: ApplicationDbcontextModelSnapshot.cs (regenerated)
# Actually, keep snapshots for consistency

# ASP.NET Core logs
logs/
*.log

# ===========================
# Node.js / Frontend
# ===========================

# Dependencies (NEVER commit node_modules!)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build output (generated by npm run build)
dist/
build/
.vite/
*.log

# Cache
.npm/
.eslintcache
.stylelintcache

# ===========================
# Testing
# ===========================

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.html

# Coverage
coverage/
*.coveragexml
*.coverage

